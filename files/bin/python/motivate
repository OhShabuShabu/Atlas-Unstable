#!/usr/bin/env python3
import os
import time
import urllib.request
import json
from datetime import date

CYAN = '\033[96m'
YELLOW = '\033[93m'
RESET = '\033[0m'

CACHE_DIR = os.path.expanduser("~/.cache")
    CACHE_FILE = os.path.join(CACHE_DIR, "motivate_quote")
os.makedirs(CACHE_DIR, exist_ok=True)

def fetch_quote():
    try:
        req = urllib.request.Request(
            'https://zenquotes.io/api/random',
            headers={'User-Agent': 'Mozilla/5.0'}
        )
        with urllib.request.urlopen(req, timeout=5) as response:
            data = json.loads(response.read().decode())
            quote = data[0].get('q', '')
            author = data[0].get('a', 'Unknown')
            today = date.today().isoformat()
            with open(CACHE_FILE, 'w') as f:
                f.write(f"{today}|{quote}|{author}")
            return quote, author
    except Exception:
        return None, None

def main():
    quote = author = "Unknown"
    today = date.today().isoformat()
    
    if os.path.exists(CACHE_FILE):
        try:
            with open(CACHE_FILE) as f:
                content = f.read().strip().split("|")
                if len(content) == 3 and content[0] == today:
                    quote, author = content[1], content[2]
                else:
                    new_quote, new_author = fetch_quote()
                    if new_quote is not None:
                        quote, author = new_quote, new_author
        except Exception:
            pass
    else:
        new_quote, new_author = fetch_quote()
        if new_quote is not None:
            quote, author = new_quote, new_author

    print()
    print(f"{CYAN}{quote}{RESET}")
    print(f"{YELLOW}— {author}{RESET}")
    print()

if __name__ == "__main__":
    main()